# Copy to .env.local (gitignored) and fill in real values.
# Source before starting the openclaw gateway: `set -a; source .env.local; set +a`
#
# The model provider API key var name depends on which provider you pick during
# onboard-agent.sh — e.g. OPENAI_API_KEY, MINIMAX_API_KEY, etc. Add the right
# one here. The wizard will tell you which.

# Model provider API key (replace var name with whatever your provider uses)
PROVIDER_API_KEY=CHANGE_ME

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=CHANGE_ME

# Your numeric Telegram user ID from @userinfobot — onboard-agent.sh fills this in
TELEGRAM_OWNER_ID=CHANGE_ME

# Mission Control runs locally per install. setup-openclaw.sh installs MC and
# fills these in automatically (extracts key from MC's generated .env, or
# generates one if extraction fails). Override URL later for tailscale exposure.
MC_URL=http://localhost:3000
MC_API_KEY=CHANGE_ME

# Where the agent's memory-wiki writes markdown files. Default is an isolated
# folder; set to your existing Obsidian vault to have the agent share it.
# Must be an absolute path (no ~ expansion). Leave unset to use the default.
#   Default:  $HOME/.openclaw/wiki/main
#   Example:  /Users/you/Documents/SecondBrain
VAULT_PATH=

# Optional: comma-separated fallback model chain in provider/model format.
# When the primary model returns auth/rate-limit/overloaded/timeout errors,
# OpenClaw advances through this chain. Leave empty for no failover.
# Example: FALLBACK_MODELS=openai/gpt-5,gemini/gemini-2.0-flash
# Triggers failover: auth failures, rate limits, overloaded, timeouts, billing.
# Does NOT trigger: context overflow, explicit aborts.
FALLBACK_MODELS=
